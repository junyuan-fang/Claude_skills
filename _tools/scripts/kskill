#!/usr/bin/env bash
# kskill — Claude_skills toolbox unified CLI
# Symlink to ~/.local/bin/kskill (or any directory in PATH) for global access.
#
# Examples:
#   kskill recall weixin           # FTS search
#   kskill recall weixin --summary
#   kskill list                    # list skills
#   kskill show cf-qunhe           # cat one skill
#   kskill extract --date 2026-05-14
#   kskill profile                 # cat merged profile
#   kskill profile --update        # refresh first
#   kskill context --person junyuan
#   kskill index                   # re-index
#   kskill sync                    # git pull/push
set -euo pipefail

REPO="${CLAUDE_SKILLS_REPO:-/home/xinmiao/code/Claude_skills}"
PY="${PYTHON:-python3}"
SCRIPTS="$REPO/_tools/scripts"
DATA="$REPO/_tools/data"

cmd="${1:-help}"; shift || true

case "$cmd" in
  recall)
    "$PY" "$SCRIPTS/query-history.py" "$@"
    ;;
  index)
    "$PY" "$SCRIPTS/index-sessions.py" "$@"
    ;;
  extract)
    "$PY" "$SCRIPTS/extract-skill.py" "$@"
    ;;
  profile)
    if [[ "${1:-}" == "--update" || "${1:-}" == "-u" ]]; then
      shift
      "$PY" "$SCRIPTS/update-user-profile.py" --days 7 --per-user "$@"
    fi
    echo "=== merged profile ==="
    cat "$DATA/user-profile.md" 2>/dev/null || echo "(none yet — run: kskill profile --update)"
    if [[ -d "$DATA/profiles" ]]; then
      echo
      echo "=== per-user profiles ==="
      ls -1 "$DATA/profiles/" 2>/dev/null
    fi
    ;;
  context)
    "$PY" "$SCRIPTS/cross-platform-context.py" "$@"
    ;;
  archive)
    "$PY" "$SCRIPTS/archive-session.py" "$@"
    ;;
  list|ls)
    for d in "$REPO"/*/; do
      [ -f "$d/SKILL.md" ] || continue
      name=$(basename "$d")
      desc=$(awk '/^description:/{sub(/^description: */,""); print; exit}' "$d/SKILL.md")
      printf '%-32s %s\n' "$name" "$desc"
    done
    ;;
  show|cat)
    slug="${1:?usage: kskill show <slug>}"
    cat "$REPO/$slug/SKILL.md"
    ;;
  sync)
    cd "$REPO"
    git pull --rebase --autostash
    git push
    ;;
  help|--help|-h|"")
    grep -E "^#" "$0" | sed 's/^# \?//' | head -25
    echo
    echo "Subcommands:"
    echo "  recall <query>      — FTS search history"
    echo "  index               — rebuild SQLite index"
    echo "  extract             — LLM-extract skills from a session"
    echo "  profile [--update]  — view/refresh user profile"
    echo "  context             — cross-platform recent activity"
    echo "  archive             — dump session to markdown"
    echo "  list                — list all skills"
    echo "  show <slug>         — cat a skill's SKILL.md"
    echo "  sync                — git pull + push"
    ;;
  *)
    echo "unknown subcommand: $cmd" >&2
    exit 2
    ;;
esac
